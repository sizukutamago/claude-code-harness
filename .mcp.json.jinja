{%- if use_playwright_mcp or use_figma_mcp -%}
{
  "mcpServers": {
    {%- if use_playwright_mcp %}
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }{% if use_figma_mcp %},{% endif %}
    {%- endif %}
    {%- if use_figma_mcp %}
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp"
    }
    {%- endif %}
  }
}
{%- endif -%}
